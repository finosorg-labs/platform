@PACKAGE_INIT@

# Determine platform-specific build directory
if(CMAKE_SYSTEM_NAME STREQUAL "Linux")
    set(PLATFORM_BUILD_DIR "linux_amd64")
elseif(CMAKE_SYSTEM_NAME STREQUAL "Darwin")
    if(CMAKE_SYSTEM_PROCESSOR MATCHES "arm64|aarch64")
        set(PLATFORM_BUILD_DIR "darwin_arm64")
    else()
        set(PLATFORM_BUILD_DIR "darwin_amd64")
    endif()
elseif(CMAKE_SYSTEM_NAME STREQUAL "Windows")
    set(PLATFORM_BUILD_DIR "windows_amd64")
endif()

# Get the directory where this config file is located
get_filename_component(FINKIT_PLATFORM_CMAKE_DIR "${CMAKE_CURRENT_LIST_FILE}" PATH)
get_filename_component(FINKIT_PLATFORM_ROOT_DIR "${FINKIT_PLATFORM_CMAKE_DIR}/../../.." ABSOLUTE)

# Define merged static library path (includes gmp and mpfr)
set(FINKIT_PLATFORM_STATIC_LIB "${FINKIT_PLATFORM_ROOT_DIR}/build/${PLATFORM_BUILD_DIR}/libfinkit_platform_static.a")

# Include the targets file
include("${CMAKE_CURRENT_LIST_DIR}/finkit-platformTargets.cmake")

# The finkit::platform target already includes all dependencies (gmp, mpfr, m)
# No additional linking is required

check_required_components(finkit-platform)

